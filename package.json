{
    "displayName": "Homebridge CT200 Revived",
    "name": "homebridge-ct200-revived",
    "version": "2.3.0",
    "description": "Homebridge plugin to control Bosch CT200 smart thermostat. Maintained fork of homebridge-ct200 with Node 24 and Homebridge 2.0 support.",
    "license": "MIT",
    "author": "Domas Kalinauskas",
    "contributors": [
        "Nils Klemm"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/nils5002/homebridge-ct200-revived.git"
    },
    "bugs": {
        "url": "https://github.com/nils5002/homebridge-ct200-revived/issues"
    },
    "engines": {
        "node": ">=20.17.0",
        "homebridge": "^1.3.5 || ^2.0.0-beta.0 || ^2.0.0"
    },
    "main": "dist/index.js",
    "scripts": {
        "lint": "eslint src/**.ts --max-warnings=0",
        "watch": "npm run build && npm link && nodemon",
        "build": "rimraf ./dist && tsc",
        "prepublishOnly": "npm run lint && npm run build"
    },
    "keywords": [
        "homebridge-plugin",
        "homekit",
        "bosch",
        "ct200"
    ],
    "dependencies": {
        "bosch-xmpp": "^2.0.0"
    },
    "devDependencies": {
        "@types/node": "^16.10.9",
        "@typescript-eslint/eslint-plugin": "^5.0.0",
        "@typescript-eslint/parser": "^5.0.0",
        "eslint": "^8.0.1",
        "homebridge": "^1.3.5",
        "nodemon": "^2.0.13",
        "rimraf": "^3.0.2",
        "ts-node": "^10.3.0",
        "typescript": "^4.4.4"
    }
}
